[flake8]
ignore = E501, E203, E121, E123, E126, W503, W504
per-file-ignores =
    # DATABASE_SPECIES uses aligned dict values for readability (intentional)
    api/utils/gene_id_utils.py: E241
exclude =
    .git,
    .venv,
    __pycache__,
    api/Archive,
    data,
    docs,
    instance,
    output,
    venv
